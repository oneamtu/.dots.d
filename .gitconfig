[user]
  name = Octavian Neamțu
  email = octavian.neamtu@generac.com
[color]
  ui = true
[alias]
  ci = commit
  st = status
  br = branch
  co = checkout
  p = push -u
[core]
	editor = nvim
  excludesfile = ~/.gitignore
[pull]
  rebase = true
[push]
	default = current
[rerere]
  enabled = true
[rebase]
  autostash = true
[stash]
  showPatch = true
[receive]
  fsckObjects = true
[url "https://github.com/"]
	insteadOf = ssh://git@github.com/
[init]
	defaultBranch = main
[credential "https://github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
[url "https://"]
	insteadOf = git://
[diff]
	tool = nvimdiff
[merge]
	tool = nvimdiff
[difftool]
	prompt = false
